# Example environment configuration for OpenRouter integration
# Copy this to .env and update with your actual API keys

# OpenRouter Configuration (recommended for new users)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_PROXY=true
OPENROUTER_SITE_URL=https://your-site.com
OPENROUTER_SITE_NAME=ComfyUI-IF_Gemini

# Alternative: Direct base URL configuration
# GEMINI_BASE_URL=https://openrouter.ai/api/v1

# Standard Gemini API (existing users)
# GEMINI_API_KEY=your-gemini-key-here

# apiyi.com / Nano Banana Configuration
# Get your API key from https://apiyi.com
# GEMINI_API_KEY=your-apiyi-api-key-here
# GEMINI_BASE_URL=https://vip.apiyi.com/v1
#
# Available Nano Banana models:
# - gemini-2.5-flash-image       (Nano Banana   - $0.025/call)
# - gemini-3.1-flash-image-preview (Nano Banana 2 - $0.03/call)
# - gemini-3-pro-image-preview   (Nano Banana Pro - $0.05/call)

# Notes:
# - OPENROUTER_API_KEY: Your OpenRouter API key from https://openrouter.ai/keys
# - OPENROUTER_PROXY=true: Automatically enables OpenRouter base URL
# - OPENROUTER_SITE_URL: Optional, for OpenRouter leaderboards
# - OPENROUTER_SITE_NAME: Optional, shown in OpenRouter analytics
#
# For the free image preview model, use:
# Model name: google/gemini-2.5-flash-image-preview:free